# =============================================================================
# AgentsApp — environment variables
# Copy this file to .env.local for development. NEVER commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Public Supabase project URL (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key (safe to expose, but should be paired with RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (SERVER ONLY — bypasses RLS).
# Used by route handlers / server actions for privileged writes.
# DO NOT expose this to the browser. DO NOT commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Session signing secret — required for /auth/login, /api/me and middleware.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 chars. NEVER reuse across environments.
# -----------------------------------------------------------------------------
AUTH_SECRET=

# -----------------------------------------------------------------------------
# WhatsApp — Meta Cloud API (webhook subscription)
# -----------------------------------------------------------------------------
# Free-form string set in the Meta App webhook config and echoed back during
# the GET handshake.
WHATSAPP_VERIFY_TOKEN=agentsapp_bot_verify_token

# Meta App Secret. When set, /api/whatsapp/webhook will require a valid
# x-hub-signature-256 header on every POST. Leave blank in dev to disable.
WHATSAPP_APP_SECRET=

# -----------------------------------------------------------------------------
# WhatsApp — GallaBox (BSP for outbound replies)
# -----------------------------------------------------------------------------
GALLABOX_API_KEY=
GALLABOX_API_SECRET=
GALLABOX_CHANNEL_ID=
